one‚Ñö‚â°1 : one‚Ñö ‚â° 1
one‚Ñö‚â°1 = refl

-- the Cassini gap 1/D¬≤ is driven below any Œµ > 0.
recip‚Üí0 : (Œµ : ‚Ñö) ‚Üí 0 < Œµ
        ‚Üí ‚à• Œ£[ n ‚àà ‚Ñï ] ([ pos 1 / (fibP (dbl n) ¬∑‚Çä‚ÇÅ fibP (dbl n)) ] < Œµ) ‚à•‚ÇÅ
recip‚Üí0 Œµ 0<Œµ = PT.map step (‚Ñö-archimedean Œµ 0<Œµ)
  where
    step : Œ£[ m ‚àà ‚Ñï ] ([ pos 1 / 1+ m ] < Œµ)
         ‚Üí Œ£[ n ‚àà ‚Ñï ] ([ pos 1 / (fibP (dbl n) ¬∑‚Çä‚ÇÅ fibP (dbl n)) ] < Œµ)
    step (m , h) = suc m ,
      isTrans‚â§< [ pos 1 / (D ¬∑‚Çä‚ÇÅ D) ] [ pos 1 / 1+ m ] Œµ recip-le h
      where
        D : ‚Ñï‚Çä‚ÇÅ
        D = fibP (dbl (suc m))
        X : ‚Ñï
        X = ‚Ñï‚Çä‚ÇÅ‚Üí‚Ñï D
        sucm‚â§X : suc m ‚â§‚Ñï X
        sucm‚â§X = ‚â§-trans (suc-‚â§-suc (‚â§-trans (M‚â§dbl m) (1 , refl)))
                         (fpN-lower (suc (dbl m)))
        sucm‚â§XX : suc m ‚â§‚Ñï ‚Ñï‚Çä‚ÇÅ‚Üí‚Ñï (D ¬∑‚Çä‚ÇÅ D)
        sucm‚â§XX = subst (suc m ‚â§‚Ñï_) (sym (n‚Üí‚Ñï¬∑‚Çä‚ÇÅ D D))
                    (‚â§-trans sucm‚â§X (le-mult X X (fpN-pos (dbl (suc m)))))
        recip-le : [ pos 1 / (D ¬∑‚Çä‚ÇÅ D) ] ‚â§ [ pos 1 / 1+ m ]
        recip-le = subst2 _‚â§‚Ñ§_ (sym (¬∑IdL‚Ñ§ (‚Ñï‚Çä‚ÇÅ‚Üí‚Ñ§ (1+ m))))
                               (sym (¬∑IdL‚Ñ§ (‚Ñï‚Çä‚ÇÅ‚Üí‚Ñ§ (D ¬∑‚Çä‚ÇÅ D))))
                               (posMono sucm‚â§XX)

-- THE COFINALITY:  q below œÜ ‚üπ q below some running convergent.
cut-to-runs : (q : ‚Ñö) ‚Üí ‚ü¶ œÜL ‚üß q ‚Üí ‚à• Œ£[ n ‚àà ‚Ñï ] (q < lo n) ‚à•‚ÇÅ
cut-to-runs q = PT.rec squash‚ÇÅ branch
  where
    -- q < lo 0  (= 1) for any q below 1.
    below1 : (q : ‚Ñö) ‚Üí q < 1 ‚Üí Œ£[ n ‚àà ‚Ñï ] (q < lo n)
    below1 q q<1 = 0 , q<1

    -- 0 < lo n  (lo n ‚â• lo 0 = 1 > 0).
    0<lon : (n : ‚Ñï) ‚Üí 0 < lo n
    0<lon n = isTrans<‚â§ 0 1 (lo n) 0<1‚Ñö (lo-mono 0 n zero-‚â§)

    branch : (q < 0) ‚äé ((q ¬∑ q) < (q + 1)) ‚Üí ‚à• Œ£[ n ‚àà ‚Ñï ] (q < lo n) ‚à•‚ÇÅ
    branch (inl q<0) = ‚à£ below1 q (isTrans< q 0 1 q<0 0<1‚Ñö) ‚à£‚ÇÅ
    branch (inr qsq) with <Dec q 1
    ... | yes q<1 = ‚à£ below1 q q<1 ‚à£‚ÇÅ
    ... | no ¬¨q<1 = PT.map use (recip‚Üí0 gapq 0<gapq)
      where
        1‚â§q : 1 ‚â§ q
        1‚â§q = ‚âÆ‚Üí‚â• q 1 ¬¨q<1
        gapq : ‚Ñö
        gapq = (q + 1) + (- (q ¬∑ q))
        0<gapq : 0 < gapq
        0<gapq = subst (_< gapq) (+InvR (q ¬∑ q))
                   (<-+o (q ¬∑ q) (q + 1) (- (q ¬∑ q)) qsq)
        use : Œ£[ n ‚àà ‚Ñï ] ([ pos 1 / (fibP (dbl n) ¬∑‚Çä‚ÇÅ fibP (dbl n)) ] < gapq)
            ‚Üí Œ£[ n ‚àà ‚Ñï ] (q < lo n)
        use (n , hn) = n , quad-squeeze q (lo n) qlt 1<q+lon
          where
            d : ‚Ñö
            d = [ pos 1 / (fibP (dbl n) ¬∑‚Çä‚ÇÅ fibP (dbl n)) ]
            h1 : (lo n + 1) ‚â° ((lo n ¬∑ lo n) + d)
            h1 = subst (Œª z ‚Üí (lo n + z) ‚â° ((lo n ¬∑ lo n) + d)) one‚Ñö‚â°1
                   (sym (loPlus1‚â° n) ‚àô gapForm n)
            floEq : ((lo n ¬∑ lo n) + (- lo n)) ‚â° (1 + (- d))
            floEq = r1 ‚ÑöCommRing (lo n ¬∑ lo n) (lo n) d
                  ‚àô cong (Œª z ‚Üí (z + (- d)) + (- lo n)) (sym h1)
                  ‚àô r2 ‚ÑöCommRing (lo n) d
            s1 : (d + ((q ¬∑ q) + (- q))) < gapq + ((q ¬∑ q) + (- q))
            s1 = <-+o d gapq ((q ¬∑ q) + (- q)) hn
            s1' : (d + ((q ¬∑ q) + (- q))) < 1
            s1' = subst ((d + ((q ¬∑ q) + (- q))) <_) (r3 ‚ÑöCommRing q (q ¬∑ q)) s1
            s2 : ((d + ((q ¬∑ q) + (- q))) + (- d)) < (1 + (- d))
            s2 = <-+o (d + ((q ¬∑ q) + (- q))) 1 (- d) s1'
            s2' : ((q ¬∑ q) + (- q)) < (1 + (- d))
            s2' = subst (_< (1 + (- d))) (r4 ‚ÑöCommRing q (q ¬∑ q) d) s2
            qlt : ((q ¬∑ q) + (- q)) < ((lo n ¬∑ lo n) + (- lo n))
            qlt = subst (((q ¬∑ q) + (- q)) <_) (sym floEq) s2'
            1<q+lon : 1 < (q + lo n)
            1<q+lon = isTrans‚â§< 1 q (q + lo n) 1‚â§q
                        (subst (_< (q + lo n)) (+IdR q) (<-o+ 0 (lo n) q (0<lon n)))

-- forward order step:  q < r and 1 < q+r  ‚üπ  f(q) < f(r)   (f x = x¬≤‚àíx increasing on (¬Ω,‚àû)).
quad-mono : (q r : ‚Ñö) ‚Üí q < r ‚Üí 1 < (q + r)
          ‚Üí ((q ¬∑ q) + (- q)) < ((r ¬∑ r) + (- r))
quad-mono q r q<r 1<qr = 0<sub‚Üí<
  where
    0<r-q : 0 < (r + (- q))
    0<r-q = subst (_< (r + (- q))) (+InvR q) (<-+o q r (- q) q<r)
    0<r+q-1 : 0 < ((r + q) + (- 1))
    0<r+q-1 = subst (_< ((r + q) + (- 1))) (+InvR 1)
                (<-+o 1 (r + q) (- 1) (subst (1 <_) (+Comm q r) 1<qr))
    0<prod : 0 < ((r + (- q)) ¬∑ ((r + q) + (- 1)))
    0<prod = subst (_< ((r + (- q)) ¬∑ ((r + q) + (- 1)))) (¬∑AnnihilL ((r + q) + (- 1)))
               (<-¬∑o 0 (r + (- q)) ((r + q) + (- 1)) 0<r+q-1 0<r-q)
    0<diff : 0 < (((r ¬∑ r) + (- r)) + (- ((q ¬∑ q) + (- q))))
    0<diff = subst (0 <_) (sym (r5 ‚ÑöCommRing q r)) 0<prod
    0<sub‚Üí< : ((q ¬∑ q) + (- q)) < ((r ¬∑ r) + (- r))
    0<sub‚Üí< = subst2 _<_ (+IdL ((q ¬∑ q) + (- q)))
                (sym (+Assoc ((r ¬∑ r) + (- r)) (- ((q ¬∑ q) + (- q))) ((q ¬∑ q) + (- q)))
                  ‚àô cong (((r ¬∑ r) + (- r)) +_) (+InvL ((q ¬∑ q) + (- q))) ‚àô +IdR ((r ¬∑ r) + (- r)))
                (<-+o 0 (((r ¬∑ r) + (- r)) + (- ((q ¬∑ q) + (- q)))) ((q ¬∑ q) + (- q)) 0<diff)

-- THE CONVERSE BRIDGE:  q below some convergent ‚üπ q ‚àà œÜL  (q below œÜ).
runs‚Üícut : (q : ‚Ñö) ‚Üí ‚à• Œ£[ n ‚àà ‚Ñï ] (q < lo n) ‚à•‚ÇÅ ‚Üí ‚ü¶ œÜL ‚üß q
runs‚Üícut q = PT.rec squash‚ÇÅ wit
  where
    wit : Œ£[ n ‚àà ‚Ñï ] (q < lo n) ‚Üí ‚ü¶ œÜL ‚üß q
    wit (n , q<lon) with <Dec q 0
    ... | yes q<0 = ‚à£ inl q<0 ‚à£‚ÇÅ
    ... | no ¬¨q<0 with <Dec q 1
    ...   | yes q<1 = ‚à£ inr (small-quad q (‚âÆ‚Üí‚â• q 0 ¬¨q<0) q<1) ‚à£‚ÇÅ
    ...   | no ¬¨q<1 = ‚à£ inr qsq ‚à£‚ÇÅ
      where
        0<lon-n : 0 < lo n
        0<lon-n = isTrans<‚â§ 0 1 (lo n) 0<1‚Ñö (lo-mono 0 n zero-‚â§)
        1<q+lon : 1 < (q + lo n)
        1<q+lon = isTrans‚â§< 1 q (q + lo n) (‚âÆ‚Üí‚â• q 1 ¬¨q<1)
                    (subst (_< (q + lo n)) (+IdR q) (<-o+ 0 (lo n) q 0<lon-n))
        flon<1 : ((lo n ¬∑ lo n) + (- lo n)) < 1
        flon<1 = subst (((lo n ¬∑ lo n) + (- lo n)) <_) (r6 ‚ÑöCommRing (lo n))
                   (<-+o (lo n ¬∑ lo n) (lo n + 1) (- lo n) (golden-lower-faithful n))
        fq<1 : ((q ¬∑ q) + (- q)) < 1
        fq<1 = isTrans< ((q ¬∑ q) + (- q)) ((lo n ¬∑ lo n) + (- lo n)) 1
                 (quad-mono q (lo n) q<lon 1<q+lon) flon<1
        qsq : (q ¬∑ q) < (q + 1)
        qsq = subst2 _<_ (r7 ‚ÑöCommRing q (q ¬∑ q)) (+Comm 1 q)
                (<-+o ((q ¬∑ q) + (- q)) 1 q fq<1)

