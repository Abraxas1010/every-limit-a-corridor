{-# OPTIONS --cubical --safe --guardedness #-}
--
-- THE COFINALITY вҖ” every rational below ПҶ is below some running convergent  (Item A, converse).
--
-- The Dedekind cut of ПҶ is GENERATED by the running corridor: cut-to-runs says q вҲҲ ПҶL вҹ№ вҲғn, q < lo n.
-- With the landed DedekindBridge.lo<ПҶ (вҲғn, q<lo n вҹ№ q вҲҲ ПҶL) this makes ПҶL q вҹә вҲғn, q < lo n вҖ” the two
-- ПҶ's (the Dedekind point and the running corridor) have the SAME cut.  Engine: the Cassini gap
-- 1/DВІ (GapBound) вҶ’ 0 (recipвҶ’0, via Forcing's unbounded denominators + в„ҡ-archimedean), so f(lo n) =
-- 1 вҲ’ 1/DВІ climbs past f(q) for any q below ПҶ, and quad-squeeze reflects that to q < lo n.
--
module corpus.cubical_agda.Corridor.Running.General.Cofinal where

open import Cubical.Foundations.Prelude
open import Cubical.Data.Nat using (в„•; suc; zero) renaming (_В·_ to _В·в„•_; _+_ to _+в„•_)
open import Cubical.Data.Nat.Order using (вүӨ-trans; suc-вүӨ-suc) renaming (_вүӨ_ to _вүӨв„•_)
open import Cubical.Data.NatPlusOne using (в„•вӮҠвӮҒ; 1+_; _В·вӮҠвӮҒ_; в„•вӮҠвӮҒвҶ’в„•)
open import Cubical.Data.Int using (в„Ө; pos) renaming (_В·_ to _В·в„Ө_; В·IdL to В·IdLв„Ө)
open import Cubical.Data.Int.Order using () renaming (_вүӨ_ to _вүӨв„Ө_; _<_ to _<в„Ө_)
open import Cubical.Data.Sigma using (ОЈ-syntax; _,_)
open import Cubical.HITs.PropositionalTruncation as PT using (вҲҘ_вҲҘвӮҒ)
open import Cubical.Data.Rationals
open import Cubical.Data.Rationals.Order using (_<_; _вүӨ_; isTransвүӨ<)
open import corpus.cubical_agda.Corridor.Running.Bracket using (fibP; dbl)
open import corpus.cubical_agda.Corridor.Running.Forcing using (fpN; fpN-lower; fpN-pos; le-mult; MвүӨdbl)
open import corpus.cubical_agda.Corridor.Running.LocatedLaw using (nвҶ’в„•В·вӮҠвӮҒ)
open import corpus.cubical_agda.Corridor.Running.General.Archimedean using (в„ҡ-archimedean)
open import corpus.cubical_agda.Corridor.Running.General.GeometricBoundQ using (posMono)

-- the Cassini gap 1/DВІ is driven below any Оө > 0.
recipвҶ’0 : (Оө : в„ҡ) вҶ’ 0 < Оө
        вҶ’ вҲҘ ОЈ[ n вҲҲ в„• ] ([ pos 1 / (fibP (dbl n) В·вӮҠвӮҒ fibP (dbl n)) ] < Оө) вҲҘвӮҒ
recipвҶ’0 Оө 0<Оө = PT.map step (в„ҡ-archimedean Оө 0<Оө)
  where
    step : ОЈ[ m вҲҲ в„• ] ([ pos 1 / 1+ m ] < Оө)
         вҶ’ ОЈ[ n вҲҲ в„• ] ([ pos 1 / (fibP (dbl n) В·вӮҠвӮҒ fibP (dbl n)) ] < Оө)
    step (m , h) = suc m ,
      isTransвүӨ< [ pos 1 / (D В·вӮҠвӮҒ D) ] [ pos 1 / 1+ m ] Оө recip-le h
      where
        D : в„•вӮҠвӮҒ
        D = fibP (dbl (suc m))
        X : в„•
        X = в„•вӮҠвӮҒвҶ’в„• D                                  -- = fpN (dbl (suc m))
        sucmвүӨX : suc m вүӨв„• X
        sucmвүӨX = вүӨ-trans (suc-вүӨ-suc (вүӨ-trans (MвүӨdbl m) (1 , refl)))
                         (fpN-lower (suc (dbl m)))   -- suc(suc(dbl m)) вүӨ fpN(suc(suc(dbl m))) = X
        sucmвүӨXX : suc m вүӨв„• в„•вӮҠвӮҒвҶ’в„• (D В·вӮҠвӮҒ D)
        sucmвүӨXX = subst (suc m вүӨв„•_) (sym (nвҶ’в„•В·вӮҠвӮҒ D D))
                    (вүӨ-trans sucmвүӨX (le-mult X X (fpN-pos (dbl (suc m)))))
        recip-le : [ pos 1 / (D В·вӮҠвӮҒ D) ] вүӨ [ pos 1 / 1+ m ]
        recip-le = subst2 _вүӨв„Ө_ (sym (В·IdLв„Ө (в„•вӮҠвӮҒвҶ’в„Ө (1+ m))))
                               (sym (В·IdLв„Ө (в„•вӮҠвӮҒвҶ’в„Ө (D В·вӮҠвӮҒ D))))
                               (posMono sucmвүӨXX)
