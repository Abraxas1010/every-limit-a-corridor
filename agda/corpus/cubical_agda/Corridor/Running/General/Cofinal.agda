-- abstract ring rearrangements (solve! cannot run on the concrete ‚Ñö SetQuotient; BEFORE the ‚Ñö open
-- so the ring ops do not clash).
module _ (R : CommRing ‚Ñì-zero) where
  open CommRingStr (snd R)
  r1 : (xx x d : ‚ü® R ‚ü©) ‚Üí (xx + (- x)) ‚â° (((xx + d) + (- d)) + (- x))
  r1 xx x d = solve! R
  r2 : (x d : ‚ü® R ‚ü©) ‚Üí (((x + 1r) + (- d)) + (- x)) ‚â° (1r + (- d))
  r2 x d = solve! R
  r3 : (q qq : ‚ü® R ‚ü©) ‚Üí (((q + 1r) + (- qq)) + (qq + (- q))) ‚â° 1r
  r3 q qq = solve! R
  r4 : (q qq d : ‚ü® R ‚ü©) ‚Üí (((d + (qq + (- q))) + (- d))) ‚â° (qq + (- q))
  r4 q qq d = solve! R
  -- the f(x)=x¬≤‚àíx factorisation (forward order step):  f(r) ‚àí f(q) = (r‚àíq)(r+q‚àí1).
  r5 : (q r : ‚ü® R ‚ü©)
     ‚Üí (((r ¬∑ r) + (- r)) + (- ((q ¬∑ q) + (- q)))) ‚â° ((r + (- q)) ¬∑ ((r + q) + (- 1r)))
  r5 q r = solve! R
  r6 : (x : ‚ü® R ‚ü©) ‚Üí ((x + 1r) + (- x)) ‚â° 1r
  r6 x = solve! R
  r7 : (q qq : ‚ü® R ‚ü©) ‚Üí ((qq + (- q)) + q) ‚â° qq
  r7 q qq = solve! R

